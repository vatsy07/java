class Solution {
public:
    int count = 0;

    void found(int index, vector<int>& nums)
    {
        count++;

        int n = nums.size();
        int des = n - 1;
        int mag = nums[index];

        // Can reach end directly
        if (index + mag >= des)
        {
            return;
        }

        int bestIndex = index + 1;
        int bestReach = bestIndex + nums[bestIndex];

        // Start from farthest reachable position and move backward
        for (int i = min(index + mag, des); i > index; i--)
        {
            // If this position can reach the end in one more jump
            if (i + nums[i] >= des)
            {
                count++;
                return;
            }

            // Otherwise remember the position with maximum future reach
            if (i + nums[i] > bestReach)
            {
                bestReach = i + nums[i];
                bestIndex = i;
            }
        }

        found(bestIndex, nums);
    }

    int jump(vector<int>& nums) {
        if (nums.size() == 1)
            return 0;

        found(0, nums);
        return count;
    }
};
